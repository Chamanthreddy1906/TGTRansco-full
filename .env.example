# Copy this file to .env and fill in your own keys. Never commit .env itself.

# Tavily Search API (live web search for current Indian prices)
# Free: 1,000 searches/month | Get key: https://app.tavily.com
TAVILY_API_KEY=your_tavily_key_here

# Groq LLM (free, fast) | https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Server port
PORT=3000
